APP_NAME=InternMatch
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://YOUR_VPS_IP_OR_DOMAIN

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# 'db' is the docker-compose service name of the MySQL container.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=internmatch
DB_USERNAME=internmatch
DB_PASSWORD=change_this_to_a_strong_password
# Used only by the MySQL container (not by Laravel):
DB_ROOT_PASSWORD=change_this_to_a_strong_root_password

# This app stores sessions, cache and the queue in the database.
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@internmatch.com"
MAIL_FROM_NAME="${APP_NAME}"
